rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    match /users/{userId} {
      // Allow read for all authenticated users (including anonymous)
      allow read: if isAuthenticated();
      // Allow write for all authenticated users to support Neural ID system across sessions
      // WARNING: This is insecure for production but necessary for this prototype's architecture
      allow write: if isAuthenticated();
    }

    match /resources/{resourceId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /_connection_test/{testId} {
      allow read, write: if isAuthenticated();
    }
  }
}
